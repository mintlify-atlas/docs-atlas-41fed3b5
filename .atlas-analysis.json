  "keyFeatures": [
    "Automated AI-powered PR reviews with intelligent feedback",
    "Neo4j knowledge graph tracking file ownership and PR relationships",
    "Semantic memory with Mem0 for project patterns and developer habits",
    "MCP bidirectional integration with Linear, Sentry, and Slack",
    "Real-time review analytics and team metrics dashboard",
    "Parallel specialized AI agents for security, performance, and style analysis",
    "GitHub OAuth integration with webhook-based PR monitoring",
    "Self-hostable with full data ownership"
  ],
  "publicApiSurface": [
    "POST /api/v1/webhooks/github - GitHub webhook receiver",
    "GET /api/v1/repos - List repositories",
    "POST /api/v1/repos/{owner}/{repo}/install - Connect repository",
    "DELETE /api/v1/repos/{owner}/{repo}/install - Disconnect repository",
    "POST /api/v1/repos/{owner}/{repo}/rescan - Rebuild Neo4j graph",
    "GET /api/v1/reviews - PR review history",
    "GET /api/v1/analytics - Team metrics and analytics",
    "GET /api/v1/memory - List memories for repository",
    "POST /api/v1/memory - Add custom rule or memory",
    "DELETE /api/v1/memory/{id} - Delete memory",
    "GET /api/v1/memory/project-map - Project context summary",
    "GET /auth/github - GitHub OAuth flow",
    "GET /auth/github/callback - OAuth callback",
    "GET /auth/me - Current user profile",
    "POST /auth/logout - Logout user",
    "GET /health - Health check",
    "GET /mcp/sse - MCP SSE event stream",
    "POST /mcp/messages - MCP JSON-RPC messages",
    "get_recent_reviews - MCP tool for recent PR reviews",
    "get_contributor_stats - MCP tool for contributor statistics",
    "get_pr_verdict - MCP tool for PR verdict",
    "get_repo_health - MCP tool for repository health metrics"
  ]
